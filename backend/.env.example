# =============================================================================
# .env.example - Example Environment Variables Template
# =============================================================================
# This is a template showing all required environment variables.
# Copy this file as .env and fill in your actual values.
# This file is safe to commit to version control (contains no real secrets).
# =============================================================================

# PINECONE_API_KEY=your_pinecone_api_key_here
# PINECONE_INDEX_NAME=nl2sql-tables
# PINECONE_ENVIRONMENT=us-east-1

# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL_NAME=llama3-70b-8192

# SQL_SERVER_HOST=localhost
# SQL_SERVER_DATABASE=your_database_name
# SQL_SERVER_USERNAME=your_username
# SQL_SERVER_PASSWORD=your_password
# SQL_SERVER_DRIVER=ODBC Driver 17 for SQL Server

# EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
